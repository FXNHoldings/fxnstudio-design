<!doctype html>
<html lang="en-AU" prefix="og: https://ogp.me/ns#" class="no-js">
<head>
  <meta charset="UTF-8">
  <link data-optimized="2" rel="stylesheet" href="/assets/css/{{ cssFile | default('style.css') }}" />
  <title>{{ title }}</title>
  <link rel="icon" type="image/svg+xml" href="/assets/images/favicon/favicon.svg">
  <link rel="icon" type="image/png" href="/assets/images/favicon/favicon.png">
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description }}" />
  <meta name="robots" content="{{ robots | default('follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large') }}" />
  {% if canonical %}<link rel="canonical" href="{{ canonical }}" />{% endif %}
  <meta property="og:locale" content="{{ ogLocale | default('en_AU') }}" />
  <meta property="og:type" content="{{ ogType | default('website') }}" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:site_name" content="FXN Studio" />
  {% if ogImage %}
  <meta property="og:image" content="{{ ogImage }}" />
  <meta property="og:image:secure_url" content="{{ ogImage }}" />
  <meta property="og:image:alt" content="{{ title }}" />
  {% endif %}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title }}" />
  <meta name="twitter:description" content="{{ description }}" />
  {% if ogImage %}<meta name="twitter:image" content="{{ ogImage }}" />{% endif %}
</head>

<body class="{{ bodyClass | default('') }}">
  <div class="noise"></div>
  <header class="header">
    <div class="container">
      <div class="header__inner">
        <a href="/" class="header__logo header__logo-small" title="FXN Studio - web design, development and SEO studio in Perth">
          <img src="/assets/images/logo/fxnstudio_logo.svg" alt="FXN Studio" height="40">
        </a>
        <nav class="nav">
          <ul>
            <li class="menu-item{% if page.url == '/' %} current-menu-item current_page_item{% endif %}"><a href="/">Home</a></li>
            <li class="menu-item{% if '/portfolio' in page.url %} current-menu-item{% endif %}"><a href="/portfolio/">Work</a></li>
            <li class="menu-item{% if '/contact' in page.url %} current-menu-item{% endif %}"><a href="/contact/">Contact</a></li>
          </ul>
          <ul class="alt">
            <li class="alt__email"><a href="mailto:contact@fxnstudio.com" title="Email me"><span><i class="ph ph-envelope"></i> contact@fxnstudio.com</span></a></li>
            <li class="alt__contact">
              <a class="btn__black" href="/contact/" title="Contact FXN Studio" aria-label="Contact FXN Studio">
                <span>Contact</span></a>
            </li>
          </ul>
        </nav>
        <button class="header__toggle link" title="Open Navigation">
          <span class="line"></span>
          <span class="line alt"></span>
          <span class="line"></span>
        </button>
      </div>
    </div>
  </header>

  {{ content | safe }}

  <footer class="footer" id="footer">
    {% if not hideClientLogos %}
    <div class="footer-clients">
      <div class="container">
        <div class="footer-clients__logos">
          <img src="/assets/images/logos/motiv.png" alt="Motiv Ring">
          <img src="/assets/images/logos/awwwards.png" alt="Awwwards">
          <img src="/assets/images/logos/webby.png" alt="The Webby Awards">
          <img src="/assets/images/logos/mtv.png" alt="MTV">
          <img src="/assets/images/logos/factorylux.png" alt="Factorylux">
          <img src="/assets/images/logos/the-profs.png" alt="The Profs">
          <img src="/assets/images/logos/workkle.png" alt="Workkle">
          <img src="/assets/images/logos/trevor-sorbie.png" alt="Trevor Sorbie">
        </div>
      </div>
    </div>
    {% endif %}
    <div id="footer-area">
      <div class="container">
        <div class="footer-area__inner">
          <div class="footer-area__brand">
            <img src="/assets/images/logo/fxnstudio_logo.svg" alt="FXN Studio" class="footer-logo" style="width:100px;height:auto;filter:brightness(0) invert(1);margin-bottom:1.5rem;">
            <p>Based in Perth, Western Australia. I design, build and deploy brands, business websites and web apps then continue to support your business with digital marketing strategies.</p>
          </div>
          <div class="footer-area__nav">
            <ul>
              <li><a href="/">Home</a></li>
              <li><a href="/portfolio/">Work</a></li>
              <li><a href="/contact/">Contact</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div id="footer-bottom">
      <div class="container">
        <span class="copyright">&copy;2026 FXN Studio. All rights reserved.</span>
        <a href="/terms-of-services/" class="terms">Terms of Service</a>
      </div>
    </div>
  </footer>

  <script type="text/javascript" src="/assets/js/jquery.js" id="jquery-js"></script>
  {% include "partials/svgsprites.njk" %}
  <script data-optimized="1" src="/assets/js/{{ jsBundle | default('bundle.js') }}" defer></script>
</body>
</html>
